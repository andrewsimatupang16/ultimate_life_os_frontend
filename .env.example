# Local development default.
# Frontend will call FastAPI directly at http://localhost:8000 when this value is empty.
VITE_API_URL=http://localhost:8000

# Production example:
# VITE_API_URL=https://your-backend-domain.example.com

# Optional: set true only if you want to use Vite proxy /api -> http://localhost:8000.
# VITE_USE_API_PROXY=true
